# ─── BlueDart Lambda — Environment Variables ────────────────────────────────
# Copy this file as reference. Set these in:
#   AWS Console → Lambda → Configuration → Environment variables
# OR via CLI:
#   aws lambda update-function-configuration --function-name bluedart-lambda \
#     --environment "Variables={BLUEDART_LOGIN_ID=...,BLUEDART_LICENCE_KEY=...,BLUEDART_JWT_TOKEN=...,BLUEDART_API_TYPE=S,BLUEDART_ENV=production}"
#
# ⚠️  NEVER commit actual key values to source control.
# ────────────────────────────────────────────────────────────────────────────

# Your BlueDart API login ID (provided by BlueDart / DHL)
BLUEDART_LOGIN_ID=YOUR_LOGIN_ID_HERE

# Your BlueDart licence key
BLUEDART_LICENCE_KEY=YOUR_LICENCE_KEY_HERE

# (Optional) Separate licence key for Shipment Tracking if different from main key
BLUEDART_TRACKING_LICENCE_KEY=YOUR_TRACKING_LICENCE_KEY_HERE

# Credentials for JWT Token retrieval (from BlueDart / DHL)
BLUEDART_CLIENT_ID=YOUR_CLIENT_ID_HERE
BLUEDART_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# JWT token from BlueDart (rotate periodically — BlueDart tokens expire)
# Note: You can now use the 'get_token' action to fetch this dynamically
BLUEDART_JWT_TOKEN=YOUR_JWT_TOKEN_HERE

# "S" = production credentials, "T" = test/sandbox credentials
BLUEDART_API_TYPE=S

# Which BlueDart gateway to hit: "production" or "sandbox"
BLUEDART_ENV=production

# ─── S3 Storage for AWB PDFs ────────────────────────────────────────────────
# Used when generateAwb=true is passed to generate_waybill
AWB_S3_BUCKET=commerce-production
AWB_S3_REGION=ap-south-1
AWB_S3_FOLDER=awb
